{
  "expo": {
    "name": "MedApp",
    "slug": "medapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./native/src/assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.jean.medapp",
      "adaptiveIcon": {
        "foregroundImage": "./native/src/assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "SCHEDULE_EXACT_ALARM"
      ]
    }
  }
}
